---
import type { FxComponentProps } from "@/lib/types";
import styles from "./HandScript.module.css";

interface Props extends Omit<FxComponentProps, "fallbackSrc"> {
  src: string;
  label?: string;
  color?: string;
  duration?: number;
  start?: string;
}

const {
  src,
  label,
  color = "var(--ms-moss)",
  duration = 1.4,
  start = "top 80%",
  staticMode = false,
  className,
} = Astro.props;

const svgs = import.meta.glob<string>("/src/assets/svg/script/*.svg", {
  query: "?raw",
  import: "default",
  eager: true,
});

const entry = Object.entries(svgs).find(([path]) => path === src || path.endsWith(src));
if (!entry) {
  throw new Error(
    `[HandScript] No script SVG matched src="${src}". Available: ${Object.keys(svgs).join(", ")}`,
  );
}
let svg = entry[1];

svg = svg.replace(/<svg\b/, '<svg aria-hidden="true" focusable="false"');

const fileName = entry[0].split("/").pop()!.replace(/\.svg$/, "");
const accessibleName = label ?? fileName.replace(/-/g, " ");
---

<span
  class:list={[styles.handScript, className]}
  data-fx="hand-script"
  data-duration={duration}
  data-start={start}
  data-static={staticMode ? "" : undefined}
  role="img"
  aria-label={accessibleName}
  style={`--ms-handscript-color:${color}`}
  set:html={svg}
/>

<script>
  import { initHandScript } from "@/components/fx/HandScript/handScript";

  function boot() {
    document
      .querySelectorAll<HTMLElement>('[data-fx="hand-script"]')
      .forEach((root) => {
        if (root.dataset.fxInit !== undefined) return;
        root.dataset.fxInit = "";
        const teardown = initHandScript(root);
        document.addEventListener(
          "astro:before-swap",
          () => {
            teardown();
            delete root.dataset.fxInit;
          },
          { once: true },
        );
      });
  }

  boot();
  document.addEventListener("astro:after-swap", boot);
</script>

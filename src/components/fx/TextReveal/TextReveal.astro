---
import "./TextReveal.css";

interface Props {
  class?: string;
}

const { class: className } = Astro.props;
---

<div class:list={["ms-text-reveal", className]} data-fx="text-reveal">
  <slot />
</div>

<script>
  import { initTextReveal } from "@/components/fx/TextReveal/textReveal";

  const teardowns: Array<() => void> = [];

  function boot() {
    const roots = document.querySelectorAll<HTMLElement>('[data-fx="text-reveal"]');
    roots.forEach((root) => teardowns.push(initTextReveal(root)));
  }

  if (document.fonts?.ready) {
    document.fonts.ready.then(boot);
  } else {
    boot();
  }

  document.addEventListener("astro:before-swap", () => {
    teardowns.splice(0).forEach((teardown) => teardown());
  });
</script>

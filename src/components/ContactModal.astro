---
const interests = [
  "Civil society partnership",
  "Non-profit collaboration",
  "Bonn Climate Conference 2026",
  "Nature retreats",
  "Other",
];
const sprig = `<svg viewBox="0 0 24 18" fill="currentColor"><path d="M12 16.5 C12 11.5 9.2 8.2 5 7 C5.8 12 8 15.4 12 16.5 Z"/><path d="M12 16.5 C12 11.5 14.8 8.2 19 7 C18.2 12 16 15.4 12 16.5 Z"/></svg>`;
---

<div
  class="ms-modal"
  id="contact-modal"
  role="dialog"
  aria-modal="true"
  aria-labelledby="contact-modal-title"
  aria-hidden="true"
>
  <div class="ms-modal__overlay" data-close-contact></div>

  <div class="ms-modal__panel">
    <!-- Drag handle (mobile visual cue) -->
    <div class="ms-modal__handle" aria-hidden="true"></div>

    <!-- Sticky header -->
    <div class="ms-modal__hd">
      <button class="ms-modal__close" type="button" aria-label="Close" data-close-contact>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
          <path d="M6 6l12 12M18 6L6 18" />
        </svg>
      </button>

      <p class="ms-modal__eyebrow">
        <span class="ms-modal__sprig" aria-hidden="true" set:html={sprig}></span>
        Join the initiative
      </p>
      <h2 class="ms-modal__title" id="contact-modal-title">
        Tell us how you would like to collaborate.
      </h2>
      <p class="ms-modal__intro">Share a few details and we will be in touch.</p>
    </div>

    <!-- Scrollable body -->
    <div class="ms-modal__bd">
      <div class="ms-cform__sent" hidden>
        <span class="ms-cform__sent-icon" aria-hidden="true">
          <svg viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="16" cy="16" r="13" />
            <path d="M10 16.5 L14 20.5 L22 12" />
          </svg>
        </span>
        <p class="ms-cform__sent-title">Your email client is ready.</p>
        <p class="ms-cform__sent-body">We've prepared your message — just hit send in the app that opened. We look forward to hearing from you.</p>
      </div>

      <form class="ms-cform" novalidate>
        <div class="ms-field">
          <label for="cf-name">Name</label>
          <input id="cf-name" name="name" type="text" autocomplete="name" placeholder="Your full name" required />
        </div>

        <div class="ms-field">
          <label for="cf-email">Email</label>
          <input id="cf-email" name="email" type="email" autocomplete="email" placeholder="you@example.com" required />
        </div>

        <div class="ms-field ms-field--full">
          <label for="cf-org">Organization</label>
          <input id="cf-org" name="organization" type="text" autocomplete="organization" placeholder="Company, NGO or institution" />
        </div>

        <!-- Interest: pill-style radio buttons -->
        <div class="ms-field ms-field--full">
          <span class="ms-field__label" id="cf-interest-label">Interest</span>
          <div class="ms-pills" role="group" aria-labelledby="cf-interest-label">
            {interests.map((opt, i) => (
              <label class="ms-pill">
                <input type="radio" name="interest" value={opt} checked={i === 0} />
                <span>{opt}</span>
              </label>
            ))}
          </div>
        </div>

        <div class="ms-field ms-field--full">
          <label for="cf-message">Message</label>
          <textarea id="cf-message" name="message" rows="3" placeholder="Tell us briefly about your work or idea"></textarea>
        </div>

        <button class="ms-cform__submit" type="submit">
          Send to contact@moodscale.eu
          <svg viewBox="0 0 20 12" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M1 6h17M13 1l5 5-5 5" />
          </svg>
        </button>
      </form>
    </div>
  </div>
</div>

<style>
  /* ---- Overlay ---- */
  .ms-modal {
    position: fixed;
    inset: 0;
    z-index: 200;
    display: none;
    align-items: center;
    justify-content: center;
    padding: clamp(0.75rem, 3vw, 2rem);
    overflow-y: auto;
    -webkit-overflow-scrolling: touch;
  }
  .ms-modal.is-open { display: flex; }

  .ms-modal__overlay {
    position: fixed;
    inset: 0;
    background: color-mix(in srgb, #0d1d15 64%, transparent);
    -webkit-backdrop-filter: blur(8px);
    backdrop-filter: blur(8px);
    animation: msFade 0.3s var(--ease-gentle, ease) both;
  }

  /* ---- Panel ---- */
  .ms-modal__panel {
    position: relative;
    z-index: 1;
    width: min(660px, 100%);
    background:
      radial-gradient(120% 55% at 100% 0%, color-mix(in srgb, var(--ms-haze) 55%, transparent), transparent 60%),
      var(--ms-paper);
    border: 1px solid color-mix(in srgb, var(--ms-pine) 10%, transparent);
    border-radius: var(--radius-lg);
    box-shadow: 0 40px 100px rgba(8, 16, 11, 0.42);
    animation: msPanelIn 0.4s var(--ease-calm, ease) both;
  }

  /* Drag handle (hidden on desktop) */
  .ms-modal__handle { display: none; }

  /* ---- Header ---- */
  .ms-modal__hd {
    padding: clamp(1.25rem, 3vw, 2rem) clamp(1.25rem, 3vw, 2rem) clamp(0.75rem, 2vw, 1rem);
    padding-right: clamp(3.5rem, 6vw, 4.5rem);
  }

  /* ---- Body ---- */
  .ms-modal__bd {
    padding: 0 clamp(1.25rem, 3vw, 2rem) clamp(1.25rem, 3vw, 2rem);
  }

  /* ---- Close button ---- */
  .ms-modal__close {
    position: absolute;
    top: clamp(0.75rem, 2vw, 1.1rem);
    right: clamp(0.75rem, 2vw, 1.1rem);
    inline-size: 38px;
    block-size: 38px;
    display: grid;
    place-items: center;
    border: none;
    border-radius: 50%;
    background: var(--ms-haze);
    color: var(--ms-pine);
    cursor: pointer;
    transition:
      background-color var(--dur-quick) var(--ease-gentle),
      transform var(--dur-quick) var(--ease-gentle);
  }
  .ms-modal__close svg { width: 17px; height: 17px; }
  .ms-modal__close:hover,
  .ms-modal__close:focus-visible {
    background: var(--ms-mist);
    transform: rotate(90deg);
  }

  /* ---- Eyebrow / title ---- */
  .ms-modal__eyebrow {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin: 0 0 0.4rem;
    font-family: var(--font-body);
    font-size: var(--fs-small);
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--ms-moss);
  }
  .ms-modal__sprig { display: inline-flex; color: var(--ms-leaf); }
  .ms-modal__sprig :global(svg) { display: block; width: 20px; height: auto; }

  .ms-modal__title {
    font-family: var(--font-display);
    font-weight: 500;
    font-optical-sizing: auto;
    font-variation-settings: "opsz" var(--opsz-display), "SOFT" 40;
    font-size: clamp(1.55rem, 4vw, 2.2rem);
    line-height: 1.06;
    letter-spacing: -0.02em;
    color: var(--ms-pine);
    margin: 0 0 0.3rem;
    max-width: 20ch;
  }
  .ms-modal__intro {
    margin: 0;
    color: var(--ms-ink-soft);
    font-size: var(--fs-small);
    line-height: var(--lh-body);
  }

  /* ---- Form grid ---- */
  .ms-cform {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--sp-2) var(--sp-3);
    padding-top: var(--sp-2);
  }
  .ms-field { display: grid; gap: 0.35rem; min-width: 0; }
  .ms-field--full { grid-column: 1 / -1; }

  .ms-field label,
  .ms-field__label {
    font-family: var(--font-body);
    font-size: var(--fs-small);
    font-weight: 700;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--ms-pine);
  }

  .ms-field input,
  .ms-field textarea {
    width: 100%;
    font-family: var(--font-body);
    font-size: var(--fs-body);
    color: var(--ms-ink);
    background: var(--ms-cream);
    border: 1px solid color-mix(in srgb, var(--ms-pine) 14%, transparent);
    border-radius: var(--radius);
    padding: 0.7rem 0.9rem;
    transition:
      border-color var(--dur-quick) var(--ease-gentle),
      box-shadow var(--dur-quick) var(--ease-gentle),
      background-color var(--dur-quick) var(--ease-gentle);
  }
  .ms-field textarea {
    resize: vertical;
    min-height: 5rem;
    line-height: var(--lh-body);
  }
  .ms-field input::placeholder,
  .ms-field textarea::placeholder {
    color: color-mix(in srgb, var(--ms-ink-soft) 60%, transparent);
  }
  .ms-field input:focus,
  .ms-field textarea:focus {
    outline: none;
    background: var(--ms-paper);
    border-color: var(--ms-moss);
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--ms-moss) 22%, transparent);
  }

  /* ---- Pill radio buttons ---- */
  .ms-pills {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
  }
  .ms-pill {
    display: block;
    cursor: pointer;
  }
  .ms-pill input {
    position: absolute;
    opacity: 0;
    width: 0;
    height: 0;
    pointer-events: none;
  }
  .ms-pill span {
    display: block;
    padding: 0.4rem 0.9rem;
    border-radius: 999px;
    border: 1.5px solid color-mix(in srgb, var(--ms-pine) 18%, transparent);
    background: var(--ms-cream);
    color: var(--ms-ink-soft);
    font-family: var(--font-body);
    font-size: 0.875rem;
    line-height: 1.4;
    transition:
      background-color 0.18s var(--ease-gentle),
      border-color 0.18s var(--ease-gentle),
      color 0.18s var(--ease-gentle);
    user-select: none;
    white-space: nowrap;
  }
  .ms-pill:hover span,
  .ms-pill:focus-within span {
    border-color: var(--ms-moss);
    background: var(--ms-haze);
    color: var(--ms-pine);
  }
  .ms-pill:has(input:checked) span {
    background: var(--ms-pine);
    border-color: var(--ms-pine);
    color: var(--ms-on-dark);
    font-weight: 600;
  }
  .ms-pill:has(input:checked):hover span {
    background: var(--ms-forest);
    border-color: var(--ms-forest);
  }
  .ms-pill input:focus-visible + span {
    outline: 2px solid var(--ms-moss);
    outline-offset: 2px;
  }

  /* ---- Submit ---- */
  .ms-cform__submit {
    grid-column: 1 / -1;
    margin-top: 0.25rem;
    width: 100%;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.6rem;
    border: none;
    border-radius: 999px;
    padding: 0.85rem 1.5rem;
    background: var(--ms-pine);
    color: var(--ms-on-dark);
    font-family: var(--font-body);
    font-size: var(--fs-body);
    font-weight: 700;
    cursor: pointer;
    transition:
      background-color var(--dur-quick) var(--ease-gentle),
      transform var(--dur-quick) var(--ease-gentle);
  }
  .ms-cform__submit svg {
    width: 18px;
    height: auto;
    transition: transform var(--dur-quick) var(--ease-gentle);
  }
  .ms-cform__submit:hover,
  .ms-cform__submit:focus-visible {
    background: var(--ms-forest);
    transform: translateY(-1px);
  }
  .ms-cform__submit:hover svg { transform: translateX(3px); }

  /* ---- Sent state ---- */
  .ms-cform__sent {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 0.75rem;
    padding: var(--sp-4) var(--sp-3) var(--sp-3);
  }
  .ms-cform__sent[hidden] { display: none; }
  .ms-cform__sent-icon {
    display: grid;
    place-items: center;
    inline-size: 56px;
    block-size: 56px;
    border-radius: 50%;
    background: var(--ms-haze);
    color: var(--ms-moss);
  }
  .ms-cform__sent-icon svg { width: 28px; height: auto; }
  .ms-cform__sent-title {
    margin: 0;
    font-family: var(--font-display);
    font-size: clamp(1.2rem, 3vw, 1.5rem);
    font-weight: 500;
    color: var(--ms-pine);
  }
  .ms-cform__sent-body {
    margin: 0;
    color: var(--ms-ink-soft);
    font-size: var(--fs-small);
    line-height: var(--lh-body);
    max-width: 34ch;
  }

  /* ---- Mobile: bottom sheet ---- */
  @media (max-width: 540px) {
    .ms-modal {
      padding: 0;
      align-items: flex-end;
      overflow: hidden;
    }
    .ms-modal.is-open { display: flex; }

    .ms-modal__panel {
      width: 100%;
      max-height: 94svh;
      display: flex;
      flex-direction: column;
      border: none;
      border-top: 1px solid color-mix(in srgb, var(--ms-pine) 10%, transparent);
      border-radius: var(--radius-lg) var(--radius-lg) 0 0;
      box-shadow: 0 -24px 64px rgba(8, 16, 11, 0.36);
      animation: msSheetUp 0.4s var(--ease-calm) both;
    }

    /* Drag handle */
    .ms-modal__handle {
      display: block;
      flex: 0 0 auto;
      width: 36px;
      height: 4px;
      background: color-mix(in srgb, var(--ms-pine) 18%, transparent);
      border-radius: 999px;
      margin: 0.7rem auto 0;
    }

    /* Header: fixed height, never scrolls */
    .ms-modal__hd {
      flex: 0 0 auto;
      padding: 0.6rem 1.1rem 0.75rem;
      padding-right: 3.4rem;
      border-bottom: 1px solid color-mix(in srgb, var(--ms-pine) 10%, transparent);
    }

    /* Body: scrolls independently */
    .ms-modal__bd {
      flex: 1 1 auto;
      overflow-y: auto;
      -webkit-overflow-scrolling: touch;
      padding: 0.9rem 1.1rem calc(1.25rem + env(safe-area-inset-bottom));
    }

    /* Close button anchored to header */
    .ms-modal__close {
      position: absolute;
      top: 0.9rem;
      right: 0.75rem;
      z-index: 5;
      inline-size: 34px;
      block-size: 34px;
    }
    .ms-modal__close svg { width: 15px; height: 15px; }

    .ms-modal__eyebrow { font-size: 0.68rem; margin-bottom: 0.2rem; }
    .ms-modal__sprig :global(svg) { width: 16px; }
    .ms-modal__title { font-size: 1.35rem; line-height: 1.1; margin-bottom: 0.2rem; max-width: none; }
    .ms-modal__intro { font-size: 0.78rem; }

    .ms-cform {
      grid-template-columns: 1fr;
      gap: 0.7rem;
      padding-top: 0;
    }
    .ms-field { gap: 0.25rem; }
    .ms-field label,
    .ms-field__label { font-size: 0.68rem; letter-spacing: 0.04em; }
    .ms-field input { padding: 0.7rem 0.85rem; min-height: 44px; }
    .ms-field textarea { padding: 0.7rem 0.85rem; min-height: 5rem; }
    .ms-cform__submit { padding: 0.85rem 1rem; min-height: 48px; margin-top: 0.1rem; }

    /* Pills wrap freely on mobile */
    .ms-pills { gap: 0.4rem; }
    .ms-pill span { padding: 0.45rem 0.8rem; font-size: 0.8rem; }

    /* Sent state compact */
    .ms-cform__sent { padding: var(--sp-3) var(--sp-2) var(--sp-2); }
  }

  @keyframes msFade { from { opacity: 0; } to { opacity: 1; } }
  @keyframes msSheetUp {
    from { opacity: 0; transform: translateY(100%); }
    to { opacity: 1; transform: translateY(0); }
  }
  @keyframes msPanelIn {
    from { opacity: 0; transform: translateY(14px) scale(0.985); }
    to { opacity: 1; transform: translateY(0) scale(1); }
  }
  @media (prefers-reduced-motion: reduce) {
    .ms-modal__overlay,
    .ms-modal__panel { animation: none; }
    .ms-modal__close:hover,
    .ms-cform__submit:hover { transform: none; }
  }
</style>

<script>
  function initContactModal() {
    const modal = document.getElementById("contact-modal");
    if (!modal || modal.dataset.bound === "1") return;
    modal.dataset.bound = "1";

    const form = modal.querySelector<HTMLFormElement>("form");
    const sentEl = modal.querySelector<HTMLElement>(".ms-cform__sent");
    const firstField = modal.querySelector<HTMLElement>("input:not([type=radio]), textarea");
    let lastTrigger: HTMLElement | null = null;

    const onKey = (e: KeyboardEvent) => { if (e.key === "Escape") close(); };
    const open = (trigger?: HTMLElement) => {
      lastTrigger = trigger ?? null;
      modal.classList.add("is-open");
      modal.setAttribute("aria-hidden", "false");
      document.body.style.overflow = "hidden";
      document.addEventListener("keydown", onKey);
      window.setTimeout(() => firstField?.focus(), 60);
    };
    const close = () => {
      modal.classList.remove("is-open");
      modal.setAttribute("aria-hidden", "true");
      document.body.style.overflow = "";
      document.removeEventListener("keydown", onKey);
      lastTrigger?.focus();
      if (sentEl && form) {
        sentEl.hidden = true;
        form.hidden = false;
      }
    };

    document.addEventListener("click", (e) => {
      const target = e.target as HTMLElement;
      const opener = target.closest<HTMLElement>("[data-open-contact]");
      if (opener) { e.preventDefault(); open(opener); return; }
      if (target.closest("[data-close-contact]")) { e.preventDefault(); close(); }
    });

    form?.addEventListener("submit", (e) => {
      e.preventDefault();
      if (!form.reportValidity()) return;
      const fd = new FormData(form);
      const val = (k: string) => String(fd.get(k) || "").trim();
      const subject = `MoodScale enquiry: ${val("interest") || "General"}`;
      const body = [
        `Name: ${val("name")}`,
        `Email: ${val("email")}`,
        `Organization: ${val("organization")}`,
        `Interest: ${val("interest")}`,
        "",
        "Message:",
        val("message"),
      ].join("\n");
      window.location.href = `mailto:contact@moodscale.eu?subject=${encodeURIComponent(subject)}&body=${encodeURIComponent(body)}`;
      if (sentEl && form) {
        form.hidden = true;
        sentEl.hidden = false;
      }
    });
  }

  initContactModal();
  document.addEventListener("astro:after-swap", initContactModal);
</script>

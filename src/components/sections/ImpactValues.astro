---
import TextReveal from "@/components/fx/TextReveal/TextReveal.astro";
import ScrollReveal from "@/components/fx/ScrollReveal/ScrollReveal.astro";
import LandscapeParallax from "@/components/fx/LandscapeParallax/LandscapeParallax.astro";

const sdgs = [
  { n: 3, label: "Good Health and Well-being" },
  { n: 4, label: "Quality Education" },
  { n: 5, label: "Gender Equality" },
  { n: 8, label: "Decent Work and Economic Growth" },
  { n: 10, label: "Reduced Inequalities" },
  { n: 13, label: "Climate Action" },
];
---

<section id="impact" class="ms-section ms-impact" data-theme="light">
  <div class="ms-impact__scene" aria-hidden="true">
    <LandscapeParallax
      scene="scene-landscape"
      staticMode
      fallbackSrc="/assets/images/scene-landscape.avif"
      height="100%"
      sun={false}
    />
  </div>

  <div class="ms-impact__haze" aria-hidden="true"></div>
  <div class="ms-impact__dome" aria-hidden="true"></div>
  <img class="ms-impact__mtn ms-impact__mtn--left" src="/assets/images/mountains-left.png" alt="" aria-hidden="true" width="570" height="760" loading="lazy" decoding="async" />
  <img class="ms-impact__mtn ms-impact__mtn--right" src="/assets/images/mountains-left.png" alt="" aria-hidden="true" width="570" height="760" loading="lazy" decoding="async" />

  <img class="ms-impact__bird ms-impact__bird--a" src="/assets/svg/birds/bird.svg" alt="" aria-hidden="true" width="40" height="24" loading="lazy" />
  <img class="ms-impact__bird ms-impact__bird--b" src="/assets/svg/birds/bird.svg" alt="" aria-hidden="true" width="40" height="24" loading="lazy" />
  <img class="ms-impact__bird ms-impact__bird--c" src="/assets/svg/birds/bird.svg" alt="" aria-hidden="true" width="40" height="24" loading="lazy" />

  <div class="ms-container ms-impact__inner">
    <header class="ms-impact__head">
      <TextReveal>
        <p class="ms-eyebrow ms-impact__eyebrow" data-reveal="fade">Our impact &amp; values</p>
        <div class="ms-rule" aria-hidden="true">
          <span class="ms-rule__line"></span>
          <svg class="ms-rule__sprig" viewBox="0 0 24 18" fill="currentColor" aria-hidden="true">
            <path d="M12 16.5 C12 11.5 9.2 8.2 5 7 C5.8 12 8 15.4 12 16.5 Z" />
            <path d="M12 16.5 C12 11.5 14.8 8.2 19 7 C18.2 12 16 15.4 12 16.5 Z" />
            <path d="M12 16.8 V7.4" stroke="currentColor" stroke-width="1" fill="none" stroke-linecap="round" />
          </svg>
          <span class="ms-rule__line"></span>
        </div>
        <h2 class="ms-impact__title" data-reveal="lines">
          Science, technology and<br /> nature for meaningful change.
        </h2>
        <p class="ms-impact__intro" data-reveal="fade">
          We combine the best of evidence-based care, smart insights and
          nature-connected practices to support people, communities and the
          planet.
        </p>
      </TextReveal>
    </header>

    <ScrollReveal>
      <div class="ms-hub" data-inview="group" data-stagger="0.1">
        <div class="ms-hub__deco" aria-hidden="true">
          <svg viewBox="0 0 100 100" preserveAspectRatio="xMidYMid meet">
            <circle class="ms-hub__ringline" cx="50" cy="50" r="37" />
            <g class="ms-hub__conn">
              <line x1="18.1" y1="31.3" x2="4.9" y2="31.3" />
              <line x1="81.9" y1="31.3" x2="95.1" y2="31.3" />
              <line x1="20" y1="71.6" x2="4.9" y2="71.6" />
              <line x1="80" y1="71.6" x2="95.1" y2="71.6" />
            </g>
            <g class="ms-hub__dot">
              <circle cx="4.9" cy="31.3" r="0.95" />
              <circle cx="95.1" cy="31.3" r="0.95" />
              <circle cx="4.9" cy="71.6" r="0.95" />
              <circle cx="95.1" cy="71.6" r="0.95" />
            </g>
            <g class="ms-hub__sprig">
              <g transform="translate(44 4) scale(0.5)">
                <path d="M12 16.5 C12 11.5 9.2 8.2 5 7 C5.8 12 8 15.4 12 16.5 Z" />
                <path d="M12 16.5 C12 11.5 14.8 8.2 19 7 C18.2 12 16 15.4 12 16.5 Z" />
              </g>
              <g transform="translate(19 71) scale(0.4) rotate(-42 12 12)">
                <path d="M12 16.5 C12 11.5 9.2 8.2 5 7 C5.8 12 8 15.4 12 16.5 Z" />
                <path d="M12 16.5 C12 11.5 14.8 8.2 19 7 C18.2 12 16 15.4 12 16.5 Z" />
              </g>
              <g transform="translate(71 71) scale(0.4) rotate(42 12 12)">
                <path d="M12 16.5 C12 11.5 9.2 8.2 5 7 C5.8 12 8 15.4 12 16.5 Z" />
                <path d="M12 16.5 C12 11.5 14.8 8.2 19 7 C18.2 12 16 15.4 12 16.5 Z" />
              </g>
            </g>
          </svg>
        </div>

        <div class="ms-hub__tree" aria-hidden="true">
          <img
            class="ms-tree"
            src="/assets/images/MD_impact_central_image.png"
            alt=""
            width="1254"
            height="1254"
            loading="lazy"
            decoding="async"
          />
        </div>

        <article class="ms-card ms-card--1" data-inview-item>
          <span class="ms-card__icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M12 6.4 C12 5 10.9 4 9.5 4 C8.2 4 7.2 5 7 6.2 C5.7 6.3 4.7 7.4 4.7 8.8 C4.7 9.3 4.8 9.7 5 10.1 C4.2 10.6 3.7 11.5 3.7 12.5 C3.7 13.6 4.4 14.6 5.4 15 C5.3 15.2 5.3 15.5 5.3 15.7 C5.3 17.2 6.5 18.4 8 18.4 C8.4 19.4 9.4 20 10.5 20 C11.3 20 12 19.3 12 18.5 Z" />
              <path d="M12 6.4 C12 5 13.1 4 14.5 4 C15.8 4 16.8 5 17 6.2 C18.3 6.3 19.3 7.4 19.3 8.8 C19.3 9.3 19.2 9.7 19 10.1 C19.8 10.6 20.3 11.5 20.3 12.5 C20.3 13.6 19.6 14.6 18.6 15 C18.7 15.2 18.7 15.5 18.7 15.7 C18.7 17.2 17.5 18.4 16 18.4 C15.6 19.4 14.6 20 13.5 20 C12.7 20 12 19.3 12 18.5 Z" />
              <path d="M12 6.4 V18.5 M8.4 8.6 C9.4 9.1 9.6 10.1 9.1 11 M15.6 8.6 C14.6 9.1 14.4 10.1 14.9 11" />
            </svg>
          </span>
          <div class="ms-card__text">
            <h3 class="ms-card__title">Psychology</h3>
            <p class="ms-card__body">Evidence-based care and support that empowers minds.</p>
          </div>
        </article>

        <article class="ms-card ms-card--2" data-inview-item>
          <span class="ms-card__icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" aria-hidden="true">
              <path d="M4 20 H20" />
              <rect x="5.6" y="12.5" width="3.2" height="5.5" rx="1" fill="currentColor" stroke="none" />
              <rect x="10.4" y="8.5" width="3.2" height="9.5" rx="1" fill="currentColor" stroke="none" />
              <rect x="15.2" y="5.5" width="3.2" height="12.5" rx="1" fill="currentColor" stroke="none" />
            </svg>
          </span>
          <div class="ms-card__text">
            <h3 class="ms-card__title">Technology</h3>
            <p class="ms-card__body">Smart insights and data-driven tools that enable better decisions.</p>
          </div>
        </article>

        <article class="ms-card ms-card--3" data-inview-item>
          <span class="ms-card__icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M5 19.5 C4.5 11 11 4.5 19.5 4.5 C19.5 13 13 19.5 5 19.5 Z" />
              <path d="M5 19.5 C8.5 15 12.5 11.5 16.5 9.5" />
            </svg>
          </span>
          <div class="ms-card__text">
            <h3 class="ms-card__title">Nature</h3>
            <p class="ms-card__body">Healing through connection with the natural world.</p>
          </div>
        </article>

        <article class="ms-card ms-card--4" data-inview-item>
          <span class="ms-card__icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round" aria-hidden="true">
              <path d="M12 20 C12 20 4 14.5 4 9 C4 6.5 6 4.6 8.5 4.6 C10.1 4.6 11.4 5.6 12 6.9 C12.6 5.6 13.9 4.6 15.5 4.6 C18 4.6 20 6.5 20 9 C20 14.5 12 20 12 20 Z" />
            </svg>
          </span>
          <div class="ms-card__text">
            <h3 class="ms-card__title">Happiness</h3>
            <p class="ms-card__body">Helping individuals and communities thrive together.</p>
          </div>
        </article>
      </div>
    </ScrollReveal>

    <div class="ms-sdg">
      <h3 class="ms-sdg__title">Contributing to Global Goals</h3>
      <div class="ms-rule ms-rule--sdg" aria-hidden="true">
        <span class="ms-rule__line"></span>
        <svg class="ms-rule__sprig" viewBox="0 0 24 18" fill="currentColor" aria-hidden="true">
          <path d="M12 16.5 C12 11.5 9.2 8.2 5 7 C5.8 12 8 15.4 12 16.5 Z" />
          <path d="M12 16.5 C12 11.5 14.8 8.2 19 7 C18.2 12 16 15.4 12 16.5 Z" />
          <path d="M12 16.8 V7.4" stroke="currentColor" stroke-width="1" fill="none" stroke-linecap="round" />
        </svg>
        <span class="ms-rule__line"></span>
      </div>
      <p class="ms-sdg__intro">
        MoodScale supports the United Nations Sustainable Development Goals,
        with well-being, equality, education, decent work, inclusion and
        climate action all interconnected.
      </p>
      <ScrollReveal>
        <ul class="ms-sdg__grid" data-inview="group" data-stagger="0.06">
          {
            sdgs.map((g) => (
              <li class="ms-sdg__tile" data-inview-item>
                <img
                  class="ms-sdg__icon"
                  src={`/assets/svg/sdg/sdg-${g.n}.svg`}
                  alt={`UN Sustainable Development Goal ${g.n}: ${g.label}`}
                  width="405"
                  height="405"
                  loading="eager"
                  decoding="async"
                />
              </li>
            ))
          }
        </ul>
      </ScrollReveal>
    </div>
  </div>
</section>

<style>
  .ms-impact {
    position: relative;
    padding-block-start: clamp(0px, 1vw, var(--sp-1));
    overflow-x: clip;
    overflow-y: visible;
  }
  .ms-impact__scene {
    position: absolute;
    inset: 0;
    bottom: -120px;
    z-index: 0;
    opacity: 0.14;
  }
  .ms-impact__mtn {
    position: absolute;
    bottom: 0;
    z-index: 0;
    inline-size: clamp(260px, 30vw, 510px);
    block-size: auto;
    opacity: 0.92;
    mix-blend-mode: multiply;
    pointer-events: none;
    -webkit-mask-image: linear-gradient(to top, transparent 2%, #000 22%);
    mask-image: linear-gradient(to top, transparent 2%, #000 22%);
  }
  .ms-impact__mtn--left {
    left: 0;
  }
  .ms-impact__mtn--right {
    right: 0;
    transform: scaleX(-1);
  }
  .ms-impact__haze {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 40px;
    block-size: 560px;
    z-index: 0;
    background: url("/assets/images/scene-landscape.avif") center 70% / cover no-repeat;
    opacity: 0.42;
    pointer-events: none;
    -webkit-mask-image: linear-gradient(to bottom, transparent 0%, #000 26%, #000 74%, transparent 100%);
    mask-image: linear-gradient(to bottom, transparent 0%, #000 26%, #000 74%, transparent 100%);
  }
  .ms-impact__dome {
    position: absolute;
    left: 50%;
    bottom: -150px;
    transform: translateX(-50%);
    inline-size: min(124%, 1500px);
    block-size: 700px;
    border-radius: 50%;
    background: radial-gradient(
      56% 56% at 50% 47%,
      rgba(249, 246, 239, 0.9) 0%,
      rgba(249, 246, 239, 0.82) 44%,
      rgba(249, 246, 239, 0.48) 66%,
      rgba(249, 246, 239, 0) 84%
    );
    z-index: 0;
    pointer-events: none;
  }
  .ms-impact__inner {
    position: relative;
    z-index: 1;
  }

  .ms-impact__bird {
    position: absolute;
    z-index: 0;
    inline-size: clamp(20px, 2.4vw, 34px);
    block-size: auto;
    opacity: 0.32;
    pointer-events: none;
  }
  .ms-impact__bird--a {
    top: 8%;
    right: 16%;
  }
  .ms-impact__bird--b {
    top: 12%;
    right: 22%;
    inline-size: clamp(14px, 1.7vw, 24px);
    opacity: 0.24;
  }
  .ms-impact__bird--c {
    top: 6%;
    left: 18%;
    inline-size: clamp(16px, 1.9vw, 27px);
    opacity: 0.22;
  }

  .ms-impact__head {
    max-width: 52rem;
    margin: 0 auto clamp(var(--sp-5), 6vw, var(--sp-6));
    text-align: center;
  }
  .ms-impact__eyebrow {
    color: var(--ms-sage);
    letter-spacing: 0.18em;
  }
  .ms-impact__title {
    font-family: var(--font-display);
    font-weight: 500;
    font-optical-sizing: auto;
    font-variation-settings: "opsz" var(--opsz-display), "SOFT" 40;
    font-size: var(--fs-h1);
    line-height: 1.05;
    letter-spacing: -0.02em;
    color: var(--ms-pine);
    margin: 0;
  }
  .ms-impact__intro {
    color: var(--ms-ink-soft);
    font-size: var(--fs-body);
    line-height: var(--lh-body);
    max-width: 72ch;
    margin: var(--sp-3) auto 0;
  }

  .ms-rule {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.85rem;
    color: var(--ms-sage);
    margin: var(--sp-2) auto var(--sp-3);
    max-width: 280px;
  }
  .ms-rule__line {
    height: 1px;
    width: clamp(40px, 8vw, 84px);
    background: linear-gradient(
      to var(--dir, right),
      transparent,
      color-mix(in srgb, var(--ms-sage) 55%, transparent)
    );
  }
  .ms-rule__line:first-child {
    --dir: left;
  }
  .ms-rule__sprig {
    inline-size: 22px;
    block-size: auto;
    color: color-mix(in srgb, var(--ms-moss) 75%, var(--ms-leaf));
    flex: none;
  }
  .ms-rule--sdg {
    margin-top: var(--sp-1);
    max-width: 240px;
  }

  .ms-hub {
    --tree-size: clamp(220px, 25vw, 330px);
    position: relative;
    display: grid;
    grid-template-columns: 1fr 1fr;
    grid-template-areas:
      "tree tree"
      "c1 c2"
      "c3 c4";
    gap: var(--sp-3);
    align-items: center;
    justify-items: center;
  }
  .ms-card--1 { grid-area: c1; }
  .ms-card--2 { grid-area: c2; }
  .ms-card--3 { grid-area: c3; }
  .ms-card--4 { grid-area: c4; }
  .ms-hub__tree { grid-area: tree; }

  .ms-hub__deco {
    display: none;
  }

  .ms-hub__tree {
    position: relative;
    z-index: 3;
    inline-size: var(--tree-size);
    aspect-ratio: 1;
    display: grid;
    place-items: center;
  }
  .ms-tree {
    display: block;
    inline-size: 106%;
    block-size: 106%;
    object-fit: contain;
    filter:
      drop-shadow(0 8px 16px rgba(36, 48, 39, 0.14))
      drop-shadow(0 24px 44px rgba(36, 48, 39, 0.22));
  }

  .ms-card {
    position: relative;
    z-index: 2;
    inline-size: 100%;
    max-inline-size: 300px;
    display: grid;
    grid-template-columns: auto 1fr;
    column-gap: 0.9rem;
    align-items: start;
  }
  .ms-card__icon {
    grid-column: 1;
    display: block;
    margin-top: 1px;
    color: var(--ms-pine);
  }
  .ms-card__icon svg {
    inline-size: 30px;
    block-size: 30px;
  }
  .ms-card__text {
    grid-column: 2;
  }
  .ms-card__title {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: var(--fs-h3);
    line-height: 1.12;
    letter-spacing: -0.005em;
    color: var(--ms-pine);
    margin: 0 0 0.32rem;
  }
  .ms-card__body {
    color: var(--ms-ink-soft);
    font-size: var(--fs-small);
    line-height: 1.55;
    margin: 0;
  }

  .ms-sdg {
    position: relative;
    z-index: 1;
    text-align: center;
    margin-top: clamp(var(--sp-5), 7vw, var(--sp-6));
  }
  .ms-sdg__title {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: var(--fs-h2);
    color: var(--ms-pine);
    margin: 0;
  }
  .ms-sdg__intro {
    color: var(--ms-ink-soft);
    font-size: var(--fs-body);
    line-height: var(--lh-body);
    max-width: 82ch;
    margin: var(--sp-1) auto var(--sp-4);
  }
  .ms-sdg__grid {
    list-style: none;
    margin: 0 auto;
    padding: 0;
    max-width: 850px;
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: clamp(0.85rem, 1.9vw, 1.3rem);
  }
  .ms-sdg__tile {
    aspect-ratio: 1 / 1;
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 8px 18px rgba(36, 48, 39, 0.12);
    transition: box-shadow var(--dur-quick) var(--ease-gentle);
  }
  .ms-sdg__tile:hover {
    box-shadow: 0 16px 32px rgba(36, 48, 39, 0.24);
  }
  .ms-sdg__icon {
    display: block;
    inline-size: 100%;
    block-size: 100%;
    object-fit: cover;
    transition: transform var(--dur-quick) var(--ease-gentle);
  }
  .ms-sdg__tile:hover .ms-sdg__icon {
    transform: scale(1.05);
  }
  @media (prefers-reduced-motion: reduce) {
    .ms-sdg__tile:hover .ms-sdg__icon {
      transform: none;
    }
  }

  @media (min-width: 900px) {
    .ms-hub {
      grid-template-columns: 1fr auto 1fr;
      grid-template-areas:
        "c1 tree c2"
        "c3 tree c4";
      column-gap: clamp(var(--sp-3), 4vw, var(--sp-5));
      row-gap: clamp(var(--sp-3), 4vw, var(--sp-5));
    }
    .ms-hub__tree {
      align-self: center;
      justify-self: center;
    }

    .ms-hub__deco {
      display: block;
      position: absolute;
      top: 50%;
      left: 50%;
      inline-size: calc(var(--tree-size) * 1.54);
      block-size: calc(var(--tree-size) * 1.54);
      aspect-ratio: 1;
      transform: translate(-50%, -50%);
      z-index: 0;
      pointer-events: none;
      overflow: visible;
    }
    .ms-hub__deco svg {
      display: block;
      inline-size: 100%;
      block-size: 100%;
      overflow: visible;
    }
    .ms-hub__ringline {
      fill: none;
      stroke: color-mix(in srgb, var(--ms-sage) 55%, transparent);
      stroke-width: 0.45;
      stroke-dasharray: 0.001 1.7;
      stroke-linecap: round;
    }
    .ms-hub__conn line {
      stroke: color-mix(in srgb, var(--ms-sage) 50%, transparent);
      stroke-width: 0.4;
      stroke-dasharray: 0.001 1.5;
      stroke-linecap: round;
    }
    .ms-hub__dot circle {
      fill: var(--ms-moss);
    }
    .ms-hub__sprig {
      fill: color-mix(in srgb, var(--ms-moss) 75%, var(--ms-leaf));
    }

    .ms-card--1,
    .ms-card--3 {
      justify-self: end;
      grid-template-columns: 1fr auto;
      text-align: right;
    }
    .ms-card--1 .ms-card__text,
    .ms-card--3 .ms-card__text {
      grid-column: 1;
    }
    .ms-card--1 .ms-card__icon,
    .ms-card--3 .ms-card__icon {
      grid-column: 2;
    }
    .ms-card--2,
    .ms-card--4 {
      justify-self: start;
    }
  }

  @media (prefers-reduced-motion: no-preference) {
    .ms-impact__bird {
      animation: ms-bird-drift 14s var(--ease-soft-in-out, ease-in-out) infinite;
    }
    .ms-impact__bird--b { animation-duration: 17s; animation-delay: -3s; }
    .ms-impact__bird--c { animation-duration: 19s; animation-delay: -7s; }
  }
  @keyframes ms-bird-drift {
    0%, 100% { transform: translate(0, 0); }
    50% { transform: translate(-14px, 6px); }
  }

  @media (max-width: 560px) {
    .ms-hub {
      grid-template-columns: 1fr;
      grid-template-areas:
        "tree"
        "c1"
        "c2"
        "c3"
        "c4";
    }
    .ms-sdg__grid {
      grid-template-columns: repeat(3, 1fr);
      max-width: 420px;
    }
  }
</style>

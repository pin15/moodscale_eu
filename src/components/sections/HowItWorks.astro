---
import TextReveal from "@/components/fx/TextReveal/TextReveal.astro";
import ScrollReveal from "@/components/fx/ScrollReveal/ScrollReveal.astro";

const VB = 300;
const CX = 150;
const CY = 150;
const SAMPLES = 18;
const RINGS = 7;
const BASE_R = 16;
const STEP_R = 15;

const profile = Array.from({ length: SAMPLES }, (_, a) => {
  const t = (a / SAMPLES) * Math.PI * 2;
  return 1 + 0.11 * Math.sin(t * 3 + 0.6) + 0.07 * Math.sin(t * 5 + 1.7);
});

function smoothClosedPath(pts: [number, number][]) {
  const n = pts.length;
  let d = `M ${pts[0][0].toFixed(2)} ${pts[0][1].toFixed(2)}`;
  for (let i = 0; i < n; i++) {
    const p0 = pts[(i - 1 + n) % n];
    const p1 = pts[i];
    const p2 = pts[(i + 1) % n];
    const p3 = pts[(i + 2) % n];
    const c1x = p1[0] + (p2[0] - p0[0]) / 6;
    const c1y = p1[1] + (p2[1] - p0[1]) / 6;
    const c2x = p2[0] - (p3[0] - p1[0]) / 6;
    const c2y = p2[1] - (p3[1] - p1[1]) / 6;
    d += ` C ${c1x.toFixed(2)} ${c1y.toFixed(2)}, ${c2x.toFixed(2)} ${c2y.toFixed(2)}, ${p2[0].toFixed(2)} ${p2[1].toFixed(2)}`;
  }
  return d + " Z";
}

const rings = Array.from({ length: RINGS }, (_, r) => {
  const radius = BASE_R + r * STEP_R;
  const pts = profile.map((f, a) => {
    const t = (a / SAMPLES) * Math.PI * 2;
    const drift = 1 + 0.05 * Math.sin(a * 1.3 + r * 0.85);
    const rr = radius * f * drift;
    return [CX + Math.cos(t) * rr, CY + Math.sin(t) * rr * 0.97] as [number, number];
  });
  return { d: smoothClosedPath(pts), i: r };
});

const RING_CX = 50;
const RING_CY = 48.25;
const R = 36.5;

const toRad = (d: number) => (d * Math.PI) / 180;
const polar = (d: number): [number, number] => [
  RING_CX + R * Math.cos(toRad(d)),
  RING_CY + R * Math.sin(toRad(d)),
];

const ARC_SPANS: [number, number][] = [
  [180, 246.5],   // left-side dot → top-left dot
  [293.5, 360],   // top-right dot → right-side dot
  [64, 116],      // short bottom arc
];

const buildArc = ([a0, a1]: [number, number]) => {
  const N = 72;
  const pts = Array.from({ length: N + 1 }, (_, i) => polar(a0 + ((a1 - a0) * i) / N));
  return (
    `M ${pts[0][0].toFixed(2)} ${pts[0][1].toFixed(2)}` +
    pts.slice(1).map((p) => ` L ${p[0].toFixed(2)} ${p[1].toFixed(2)}`).join("")
  );
};

const arcs = ARC_SPANS.map(buildArc);
const glints = ARC_SPANS.flatMap(([a0, a1]) => [polar(a0), polar(a1)]);
---

<section id="how-it-works" class="ms-section ms-tech" data-theme="dark">
  <img
    class="ms-tech__leafpng"
    src="/assets/images/Leaves_Tech_section.png"
    alt=""
    aria-hidden="true"
    width="1122"
    height="1402"
    loading="lazy"
    decoding="async"
  />

  <div class="ms-container ms-tech__main">
    <div class="ms-tech__head">
      <TextReveal>
        <p class="ms-eyebrow ms-tech__eyebrow" data-reveal="fade">Our approach</p>
        <h2 class="ms-tech__title" data-reveal="lines">
          Technology<br /> with empathy.
        </h2>
        <p class="ms-tech__lede" data-reveal="fade">
          Smart algorithms can help people find the right support, notice
          emotional patterns and understand their journey, but technology should
          never replace warmth, trust or human connection.
        </p>
      </TextReveal>
    </div>

    <ScrollReveal class="ms-tech__orbitwrap">
      <div class="ms-orbit">
        <svg
          class="ms-orbit__contours"
          viewBox={`0 0 ${VB} ${VB}`}
          aria-hidden="true"
        >
          {
            rings.map((ring) => (
              <path d={ring.d} style={`--ring:${ring.i}`} vector-effect="non-scaling-stroke" />
            ))
          }
        </svg>

        <svg
          class="ms-orbit__ring"
          viewBox="0 0 100 100"
          preserveAspectRatio="none"
          aria-hidden="true"
        >
          {arcs.map((d) => <path d={d} vector-effect="non-scaling-stroke" />)}
          <g class="ms-orbit__dots">
            {glints.map(([x, y]) => <circle cx={x.toFixed(2)} cy={y.toFixed(2)} r="0.72" />)}
          </g>
        </svg>

        <div class="ms-orbit__core" aria-hidden="true">
          <span class="ms-orbit__glow"></span>
          <svg class="ms-orbit__heart" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 21 C12 21 3 14.5 3 8.8 C3 6.1 5.1 4 7.7 4 C9.5 4 11 5 12 6.5 C13 5 14.5 4 16.3 4 C18.9 4 21 6.1 21 8.8 C21 14.5 12 21 12 21 Z" />
          </svg>
        </div>

        <div class="ms-orbit__nodes" data-inview="group" data-stagger="0.12">
          <article class="ms-node ms-node--1" data-inview-item>
            <span class="ms-node__disc">
              <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M12 0 C12.4 6.4 17.6 11.6 24 12 C17.6 12.4 12.4 17.6 12 24 C11.6 17.6 6.4 12.4 0 12 C6.4 11.6 11.6 6.4 12 0 Z" />
              </svg>
            </span>
            <span class="ms-node__n">01</span>
            <h3 class="ms-node__title">Smart matching</h3>
            <p class="ms-node__body">
              Thoughtful algorithms help people find the right support and notice
              emotional patterns over time.
            </p>
          </article>

          <article class="ms-node ms-node--2" data-inview-item>
            <span class="ms-node__disc">
              <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
                <circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="1.6" />
                <path d="M12 3 A9 9 0 0 0 12 21 Z" fill="currentColor" />
              </svg>
            </span>
            <span class="ms-node__n">02</span>
            <h3 class="ms-node__title">Emotional journey</h3>
            <p class="ms-node__body">
              A gentle, longitudinal view of how someone feels, so progress is
              something you can see and trust.
            </p>
          </article>

          <article class="ms-node ms-node--3" data-inview-item>
            <span class="ms-node__disc">
              <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
                <path
                  d="M12 20.5 C12 20.5 3.5 14.4 3.5 9 C3.5 6.5 5.5 4.6 8 4.6 C9.7 4.6 11.1 5.6 12 7 C12.9 5.6 14.3 4.6 16 4.6 C18.5 4.6 20.5 6.5 20.5 9 C20.5 14.4 12 20.5 12 20.5 Z"
                  stroke="currentColor"
                  stroke-width="1.6"
                  stroke-linejoin="round"
                />
              </svg>
            </span>
            <span class="ms-node__n">03</span>
            <h3 class="ms-node__title">Human-centered</h3>
            <p class="ms-node__body">
              Technology never replaces warmth. Every pathway ends with real,
              confidential human care.
            </p>
          </article>
        </div>
      </div>
    </ScrollReveal>
  </div>

  <ScrollReveal class="ms-tech__assurewrap">
    <ul class="ms-container ms-assure" data-inview="group" data-stagger="0.1">
      <li class="ms-assure__item" data-inview-item>
        <span class="ms-assure__disc">
          <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d="M12 2.8 L19.5 5.8 V11 C19.5 15.9 16.4 18.8 12 20.2 C7.6 18.8 4.5 15.9 4.5 11 V5.8 Z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round" />
            <path d="M9 11.7 L11.2 13.9 L15.2 9.6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </span>
        <p>Designed for dignity, confidentiality and emotional safety.</p>
      </li>

      <li class="ms-assure__item" data-inview-item>
        <span class="ms-assure__disc">
          <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d="M4 20 H20" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" />
            <path d="M7 20 V13.5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" />
            <path d="M12 20 V8" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" />
            <path d="M17 20 V11" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" />
          </svg>
        </span>
        <p>Grounded in evidence-based care, assessments and behaviour science.</p>
      </li>

      <li class="ms-assure__item" data-inview-item>
        <span class="ms-assure__disc">
          <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <circle cx="9" cy="8.5" r="2.8" stroke="currentColor" stroke-width="1.5" />
            <path d="M3.5 19 A5.5 5.5 0 0 1 14.5 19" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
            <circle cx="17.3" cy="8.2" r="2.2" stroke="currentColor" stroke-width="1.5" />
            <path d="M16 13.4 A5 5 0 0 1 21 18.4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
          </svg>
        </span>
        <p>Created for people, workplaces, non-profits and civil societies.</p>
      </li>
    </ul>
  </ScrollReveal>
</section>

<style>
  .ms-tech {
    overflow: clip;
    padding-block-start: clamp(var(--sp-3), 4vw, var(--sp-5));
    background:
      radial-gradient(95% 72% at 50% 44%, rgba(156, 196, 132, 0.07), transparent 58%),
      linear-gradient(180deg, #0e1f17 0%, #0b1a12 60%, #091610 100%);
  }
  .ms-tech::before {
    content: "";
    position: absolute;
    inset: 0;
    pointer-events: none;
    background:
      radial-gradient(46% 38% at 3% -6%, rgba(231, 239, 224, 0.12), transparent 70%),
      radial-gradient(60% 50% at 50% 120%, color-mix(in srgb, var(--ms-pine) 26%, transparent), transparent 72%);
  }
  .ms-tech__leaf {
    position: absolute;
    left: -14px;
    bottom: -18px;
    inline-size: clamp(170px, 18vw, 300px);
    block-size: auto;
    transform: scaleY(-1);
    opacity: 0.22;
    z-index: 0;
    pointer-events: none;
  }
  .ms-tech__leafpng {
    position: absolute;
    left: -22px;
    bottom: -18px;
    inline-size: clamp(190px, 18vw, 310px);
    block-size: auto;
    opacity: 0.4;
    z-index: 0;
    pointer-events: none;
  }

  .ms-tech__main {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(var(--sp-4), 6vw, var(--sp-6));
    align-items: center;
  }

  .ms-tech__eyebrow {
    letter-spacing: 0.16em;
  }
  .ms-tech__title {
    font-family: var(--font-display);
    font-weight: 500;
    font-optical-sizing: auto;
    font-variation-settings: "opsz" var(--opsz-display), "SOFT" 40;
    font-size: clamp(2.5rem, 5vw, 4.25rem);
    line-height: 1.02;
    letter-spacing: -0.02em;
    color: var(--ms-on-dark);
    margin: var(--sp-2) 0 0;
  }
  .ms-tech__lede {
    color: var(--ms-on-dark-soft);
    font-size: var(--fs-body);
    line-height: var(--lh-body);
    margin: var(--sp-3) 0 0;
    max-width: 42ch;
  }

  .ms-tech__orbitwrap {
    width: 100%;
  }
  .ms-orbit {
    position: relative;
    width: 100%;
    color: var(--ms-leaf);
  }
  .ms-orbit__ring,
  .ms-orbit__contours,
  .ms-orbit__core {
    display: none;
  }
  .ms-orbit__nodes {
    display: grid;
    gap: var(--sp-4);
  }

  .ms-orbit__ring {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }
  .ms-orbit__ring path {
    fill: none;
    stroke: color-mix(in srgb, var(--ms-leaf) 30%, transparent);
    stroke-width: 1.05;
    stroke-linecap: round;
    stroke-linejoin: round;
    opacity: 0.72;
  }
  .ms-orbit__dots circle {
    fill: #e3edc5;
    opacity: 0.94;
    filter: drop-shadow(0 0 3px rgba(227, 237, 197, 0.72));
    animation: ms-dot-pulse 3.8s ease-in-out infinite;
  }
  .ms-orbit__dots circle:nth-child(2n) { animation-delay: .35s; }
  .ms-orbit__dots {
    filter: drop-shadow(0 0 2px color-mix(in srgb, var(--ms-leaf) 60%, transparent));
  }
  @keyframes ms-dot-pulse {
    0%, 100% { opacity: .82; }
    50% { opacity: 1; }
  }

  .ms-orbit__contours {
    position: absolute;
    left: 50%;
    top: 57%;
    width: 38%;
    aspect-ratio: 1;
    transform: translate(-50%, -50%);
    overflow: visible;
    filter: drop-shadow(0 0 1.5px color-mix(in srgb, var(--ms-leaf) 12%, transparent));
  }
  .ms-orbit__contours path {
    fill: none;
    stroke: color-mix(in srgb, var(--ms-leaf) 82%, white);
    stroke-width: 1;
    stroke-opacity: calc(0.34 - var(--ring) * 0.03);
    animation: ms-contour-wave 3.4s ease-in-out infinite;
    animation-delay: calc((6 - var(--ring)) * 0.42s);
  }
  @keyframes ms-contour-wave {
    0%, 100% { stroke-opacity: calc(0.12 - var(--ring) * 0.006); }
    22% { stroke-opacity: calc(0.78 - var(--ring) * 0.03); }
    52% { stroke-opacity: calc(0.12 - var(--ring) * 0.006); }
  }

  .ms-orbit__core {
    position: absolute;
    left: 50%;
    top: 57%;
    width: 24%;
    aspect-ratio: 1;
    transform: translate(-50%, -50%);
    place-items: center;
  }
  .ms-orbit__glow {
    position: absolute;
    inset: -18%;
    border-radius: 50%;
    opacity: 0.58;
    background:
      radial-gradient(circle, rgba(247, 240, 214, 0.42) 0%, rgba(245, 233, 200, 0.11) 13%, transparent 34%),
      radial-gradient(circle, color-mix(in srgb, var(--ms-leaf) 9%, transparent) 0%, transparent 48%);
    filter: blur(6px);
    animation: ms-orbit-breathe 7s ease-in-out infinite;
  }
  @keyframes ms-orbit-breathe {
    0%, 100% { transform: scale(1); opacity: 0.92; }
    50% { transform: scale(1.07); opacity: 1; }
  }
  @media (prefers-reduced-motion: reduce) {
    .ms-orbit__glow,
    .ms-orbit__dots circle,
    .ms-orbit__contours path { animation: none; opacity: 1; }
  }
  .ms-orbit__heart {
    position: relative;
    width: clamp(24px, 2.8vw, 30px);
    height: auto;
    color: #fdfbf0;
    filter: drop-shadow(0 0 3px rgba(245, 233, 200, 0.35));
  }

  .ms-node {
    text-align: center;
  }
  .ms-node__disc {
    display: grid;
    place-items: center;
    inline-size: 84px;
    block-size: 84px;
    margin: 0 auto;
    border-radius: 50%;
    background:
      radial-gradient(circle at 50% 32%, color-mix(in srgb, var(--ms-leaf) 16%, transparent), transparent 70%),
      color-mix(in srgb, var(--ms-pine) 42%, transparent);
    border: 1px solid color-mix(in srgb, var(--ms-leaf) 30%, transparent);
    box-shadow:
      inset 0 1px 0 color-mix(in srgb, var(--ms-on-dark) 12%, transparent),
      0 0 0 6px color-mix(in srgb, var(--ms-leaf) 5%, transparent),
      0 12px 30px rgba(0, 0, 0, 0.28);
  }
  .ms-node__disc svg {
    inline-size: 30px;
    block-size: 30px;
    color: var(--ms-on-dark);
  }
  .ms-node__n {
    display: block;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 0.95rem;
    letter-spacing: 0.04em;
    color: color-mix(in srgb, var(--ms-sage) 80%, var(--ms-leaf));
    margin-top: 0.9rem;
  }
  .ms-node__title {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1.2rem;
    line-height: 1.2;
    color: var(--ms-on-dark);
    margin: 0.1rem 0 0.4rem;
  }
  .ms-node__body {
    color: var(--ms-on-dark-soft);
    font-size: 0.92rem;
    line-height: 1.55;
    margin: 0 auto;
    max-width: 25ch;
  }

  .ms-tech__assurewrap {
    position: relative;
    z-index: 1;
  }
  .ms-assure {
    list-style: none;
    margin: clamp(var(--sp-2), 2vw, var(--sp-3)) auto 0;
    padding: clamp(var(--sp-3), 3vw, var(--sp-4));
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--sp-3);
    background: color-mix(in srgb, var(--ms-on-dark) 4%, transparent);
    border: 1px solid color-mix(in srgb, var(--ms-on-dark) 11%, transparent);
    border-radius: var(--radius-lg);
  }
  .ms-assure__item {
    display: flex;
    align-items: center;
    gap: var(--sp-2);
  }
  .ms-assure__disc {
    flex: none;
    display: grid;
    place-items: center;
    inline-size: 52px;
    block-size: 52px;
    border-radius: 50%;
    background: color-mix(in srgb, var(--ms-leaf) 12%, transparent);
    border: 1px solid color-mix(in srgb, var(--ms-leaf) 22%, transparent);
  }
  .ms-assure__disc svg {
    inline-size: 24px;
    block-size: 24px;
    color: var(--ms-leaf);
  }
  .ms-assure__item p {
    margin: 0;
    color: var(--ms-on-dark-soft);
    font-size: 0.98rem;
    line-height: 1.5;
  }

  @media (min-width: 900px) {
    .ms-tech__main {
      grid-template-columns: 0.9fr 1.1fr;
    }

    .ms-orbit {
      aspect-ratio: 1 / 0.96;
      min-height: 560px;
    }
    .ms-orbit__ring,
    .ms-orbit__contours,
    .ms-orbit__core {
      display: grid;
    }

    .ms-orbit__nodes {
      position: absolute;
      inset: 0;
      display: block;
    }
    .ms-node {
      position: absolute;
      inline-size: 200px;
      margin-left: -100px;
      top: calc(var(--cy) - 42px);
      left: var(--x);
    }
    .ms-node--1 {
      --x: 50%;
      --cy: 8.5%;
    }
    .ms-node--2 {
      --x: 13.5%;
      --cy: 58%;
    }
    .ms-node--3 {
      --x: 86.5%;
      --cy: 58%;
    }

    .ms-assure {
      grid-template-columns: repeat(3, 1fr);
      gap: 0;
    }
    .ms-assure__item {
      padding-inline: clamp(var(--sp-2), 3vw, var(--sp-4));
    }
    .ms-assure__item + .ms-assure__item {
      border-left: 1px solid color-mix(in srgb, var(--ms-on-dark) 11%, transparent);
    }
  }

  @media (min-width: 1100px) {
    .ms-orbit {
      aspect-ratio: 1 / 0.96;
      min-height: 600px;
    }
  }
</style>

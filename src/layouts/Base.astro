---
import "@/styles/reset.css";
import "@/styles/tokens.css";
import "@/styles/fonts.css";
import "@/styles/sections.css";
import MotionProvider from "@/components/motion/MotionProvider.astro";
import { ClientRouter } from "astro:transitions";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "MoodScale EU — Reimagining Well-being with Empathy & Technology",
  description =
    "MoodScale EU is an initiative connecting mental well-being, climate resilience, civil-society action and the UN Sustainable Development Goals.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" href="/favicon.ico" />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    <link
      rel="preload"
      as="image"
      href="/assets/video/hero-bg-poster.jpg"
      fetchpriority="high"
    />

    {[3, 4, 5, 8, 10, 13].map((n) => (
      <link rel="preload" as="image" href={`/assets/svg/sdg/sdg-${n}.svg`} />
    ))}

    <ClientRouter />
  </head>
  <body>
    <slot />
    <MotionProvider />

    <style>
      img, video, svg, canvas {
        -webkit-user-select: none;
        user-select: none;
        -webkit-user-drag: none;
      }

    </style>

    <script>
      document.addEventListener('contextmenu', (e) => {
        const el = e.target as HTMLElement;
        if (el.tagName === 'IMG' || el.tagName === 'VIDEO' || el.tagName === 'SVG' ||
            el.tagName === 'CANVAS' || el.closest('img, video, svg, canvas, picture')) {
          e.preventDefault();
          return;
        }
        const style = window.getComputedStyle(el);
        if (style.backgroundImage && style.backgroundImage !== 'none') {
          e.preventDefault();
        }
      });

      document.addEventListener('dragstart', (e) => {
        const el = e.target as HTMLElement;
        if (el.tagName === 'IMG' || el.tagName === 'VIDEO' || el.closest('img, video')) {
          e.preventDefault();
        }
      });

      function lockImages() {
        document.querySelectorAll<HTMLImageElement>('img, video').forEach(el => {
          el.setAttribute('draggable', 'false');
        });
      }
      lockImages();
      document.addEventListener('astro:after-swap', lockImages);
    </script>

  </body>
</html>
